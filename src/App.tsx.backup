// --- Types & Data ---

type DeviceType = 'smartphone' | 'tablet' | 'watch' | 'console' | 'desktop' | 'laptop';

interface DeviceCategory {
  id: DeviceType;
  label: string;
  icon: React.ReactNode;
}

interface Brand {
  id: string;
  label: string;
  logo: string;
}

interface Model {
  id: string;
  label: string;
  image?: string;
}

interface Repair {
  id: string;
  title: string;
  duration: string;
  description: string;
  icon: React.ReactNode;
}

interface Location {
  id: string;
  name: string;
  description: string;
  address: string;
  phone: string;
  email: string;
  link: string;
  distance: string;
  image?: string;
  lat?: number;
  lng?: number;
  distanceValue?: number;
  hours: Record<number, { open: number; close: number }>; // index 0 (Sun) to 6 (Sat), times in minutes from midnight
}

